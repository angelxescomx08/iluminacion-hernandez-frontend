---
import AdminLayout from "../../../../layouts/AdminLayout.astro";

const productId = Astro.params.id;
if (!productId) {
    return Astro.redirect("/admin/productos");
}
---

<AdminLayout title="Editar producto — Administración">
    <div
        id="admin-edit-config"
        class="hidden"
        data-product-id={productId}
        aria-hidden="true"
    >
    </div>
    <div
        id="admin-env-alert"
        class="alert alert-warning mb-6 hidden"
        role="alert"
    >
        Configura <code class="text-xs">PUBLIC_API_URL</code> para editar
        productos.
    </div>

    <div id="admin-loading" class="flex flex-col items-center py-20 gap-4">
        <span class="loading loading-spinner loading-lg text-amber-600"
        ></span>
        <p class="text-sm text-neutral-500 font-inter">Cargando producto…</p>
    </div>

    <div id="admin-shell" class="hidden space-y-8 max-w-3xl">
        <div>
            <a
                href="/admin/productos"
                class="link link-hover text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4 inline-block"
            >
                ← Volver al listado
            </a>
            <h1
                class="text-2xl md:text-3xl font-montserrat font-bold text-neutral-900"
            >
                Editar producto
            </h1>
            <p class="text-sm text-neutral-500 mt-1">
                <code class="text-xs bg-neutral-100 px-1 rounded"
                    >PATCH /api/v1/products/:id</code
                >
                · imágenes vía
                <code class="text-xs bg-neutral-100 px-1 rounded"
                    >/images</code
                >
            </p>
        </div>

        <div
            id="admin-form-error"
            class="alert alert-error text-sm hidden"
            role="alert"
        >
        </div>

        <form
            id="product-edit-form"
            class="bg-white border border-neutral-100 rounded-2xl p-6 md:p-8 shadow-sm space-y-5"
        >
            <input type="hidden" id="field-id" value={productId} />

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-title">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Título</span
                    >
                </label>
                <input
                    id="field-title"
                    name="title"
                    required
                    class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-price">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Precio</span
                        >
                    </label>
                    <input
                        id="field-price"
                        name="price"
                        type="number"
                        step="0.01"
                        min="0"
                        required
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                    />
                </div>
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-stock">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Stock</span
                        >
                    </label>
                    <input
                        id="field-stock"
                        name="stock"
                        type="number"
                        step="1"
                        min="0"
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                    />
                </div>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-slug">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Slug (solo lectura)</span
                    >
                </label>
                <input
                    id="field-slug"
                    name="slug"
                    readonly
                    class="input input-bordered w-full bg-neutral-100 border-neutral-200 text-neutral-500"
                />
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-description">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Descripción</span
                    >
                </label>
                <textarea
                    id="field-description"
                    name="description"
                    rows="3"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-sm"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-content">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Contenido</span
                    >
                </label>
                <textarea
                    id="field-content"
                    name="content"
                    rows="5"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 font-mono text-xs"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-characteristics">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Características (JSON)</span
                    >
                </label>
                <textarea
                    id="field-characteristics"
                    name="characteristics"
                    rows="4"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-xs font-mono"
                ></textarea>
            </div>

            <label
                class="label cursor-pointer justify-start gap-3 border border-neutral-100 rounded-xl px-4 py-3 bg-neutral-50"
            >
                <input
                    id="field-active"
                    name="isActive"
                    type="checkbox"
                    class="checkbox checkbox-sm checkbox-neutral"
                />
                <span class="label-text text-sm text-neutral-600"
                    >Producto activo en catálogo</span
                >
            </label>

            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <button
                    type="submit"
                    id="btn-save"
                    class="btn btn-neutral rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] h-12 flex-1 hover:bg-amber-600"
                >
                    Guardar cambios
                </button>
                <button
                    type="button"
                    id="btn-archive"
                    class="btn btn-outline btn-error rounded-xl h-12 font-inter font-semibold border-error/40"
                >
                    Archivar
                </button>
            </div>
        </form>

        <section
            class="bg-white border border-neutral-100 rounded-2xl p-6 md:p-8 shadow-sm space-y-4"
        >
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <h2 class="font-montserrat font-bold text-lg text-neutral-900">
                    Imágenes
                </h2>
                <label
                    class="btn btn-sm btn-outline border-neutral-200 rounded-xl cursor-pointer"
                >
                    <input
                        id="image-file"
                        type="file"
                        accept="image/jpeg,image/png,image/webp"
                        class="hidden"
                    />
                    Subir imagen
                </label>
            </div>
            <p class="text-xs text-neutral-500">
                Máx. 5&nbsp;MB · JPEG, PNG o WebP ·
                <code class="text-[10px] bg-neutral-100 px-1 rounded"
                    >POST .../images</code
                >
            </p>
            <div id="images-list" class="grid gap-3 sm:grid-cols-2"></div>
        </section>
    </div>
</AdminLayout>

<script>
    import { bootAdminCatalogPage } from "../../../../catalog/client/boot-admin-catalog-page";
    import type { CatalogProduct } from "../../../../catalog/domain/product";
    import type { ProductsGatewayPort } from "../../../../catalog/ports/products-gateway.port";

    const configEl = document.getElementById("admin-edit-config");
    const productId =
        configEl instanceof HTMLElement && configEl.dataset.productId
            ? configEl.dataset.productId
            : "";

    const envAlert = document.getElementById("admin-env-alert");
    const loading = document.getElementById("admin-loading");
    const shell = document.getElementById("admin-shell");
    const errBox = document.getElementById("admin-form-error");
    const form = document.getElementById("product-edit-form");
    const saveBtn = document.getElementById("btn-save");
    const archiveBtn = document.getElementById("btn-archive");
    const imagesList = document.getElementById("images-list");
    const imageFile = document.getElementById("image-file");

    function showError(message: string) {
        if (!errBox) {
            return;
        }
        errBox.textContent = message;
        errBox.classList.remove("hidden");
    }

    function hideError() {
        errBox?.classList.add("hidden");
    }

    function parseCharacteristics(raw: string): Record<string, unknown> | undefined {
        const t = raw.trim();
        if (!t) {
            return undefined;
        }
        const parsed = JSON.parse(t) as unknown;
        if (typeof parsed !== "object" || parsed === null || Array.isArray(parsed)) {
            throw new Error("Las características deben ser un objeto JSON.");
        }
        return parsed as Record<string, unknown>;
    }

    let catalogGateway!: ProductsGatewayPort;

    function fillForm(p: CatalogProduct) {
        const titleEl = document.getElementById("field-title");
        const priceEl = document.getElementById("field-price");
        const stockEl = document.getElementById("field-stock");
        const slugEl = document.getElementById("field-slug");
        const descEl = document.getElementById("field-description");
        const contentEl = document.getElementById("field-content");
        const charEl = document.getElementById("field-characteristics");
        const activeEl = document.getElementById("field-active");
        if (titleEl instanceof HTMLInputElement) {
            titleEl.value = p.title;
        }
        if (priceEl instanceof HTMLInputElement) {
            priceEl.value = String(p.price);
        }
        if (stockEl instanceof HTMLInputElement) {
            stockEl.value =
                p.stock === null || p.stock === undefined ? "" : String(p.stock);
        }
        if (slugEl instanceof HTMLInputElement) {
            slugEl.value = p.slug;
        }
        if (descEl instanceof HTMLTextAreaElement) {
            descEl.value = p.description ?? "";
        }
        if (contentEl instanceof HTMLTextAreaElement) {
            contentEl.value = p.content ?? "";
        }
        if (charEl instanceof HTMLTextAreaElement) {
            charEl.value = p.characteristics
                ? JSON.stringify(p.characteristics, null, 2)
                : "";
        }
        if (activeEl instanceof HTMLInputElement) {
            activeEl.checked = p.isActive;
        }
    }

    function renderImages(
        p: CatalogProduct,
        resolvedProductId: string,
    ) {
        if (!imagesList) {
            return;
        }
        imagesList.innerHTML = "";
        if (p.images.length === 0) {
            const pEl = document.createElement("p");
            pEl.className = "text-sm text-neutral-500 col-span-full";
            pEl.textContent = "Aún no hay imágenes.";
            imagesList.appendChild(pEl);
            return;
        }
        for (const img of p.images) {
            const card = document.createElement("div");
            card.className =
                "flex gap-3 border border-neutral-100 rounded-xl p-3 bg-neutral-50/80";
            const mainBadge = img.isMain
                ? '<span class="badge badge-warning badge-sm">Principal</span>'
                : "";
            card.innerHTML = `
        <div class="w-24 h-24 rounded-lg overflow-hidden bg-neutral-200 shrink-0">
          <img src="${escapeAttr(img.url)}" alt="" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="min-w-0 flex-1 flex flex-col gap-2">
          <div class="flex flex-wrap gap-2 items-center">${mainBadge}</div>
          <div class="flex flex-wrap gap-2 mt-auto">
            <button type="button" class="btn btn-xs rounded-lg" data-main="${escapeAttr(img.id)}">Principal</button>
            <button type="button" class="btn btn-xs btn-ghost text-error rounded-lg" data-del="${escapeAttr(img.id)}">Eliminar</button>
          </div>
        </div>`;
            imagesList.appendChild(card);
        }

        imagesList.querySelectorAll<HTMLButtonElement>("button[data-main]").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const id = btn.dataset.main;
                    if (!id) {
                        return;
                    }
                    const res = await catalogGateway.setMainImage(
                        resolvedProductId,
                        id,
                    );
                    if (!res.ok) {
                        showError(res.message);
                        return;
                    }
                    hideError();
                    renderImages(res.data, resolvedProductId);
                });
            },
        );

        imagesList.querySelectorAll<HTMLButtonElement>("button[data-del]").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const id = btn.dataset.del;
                    if (!id) {
                        return;
                    }
                    if (!confirm("¿Eliminar esta imagen del producto?")) {
                        return;
                    }
                    const res = await catalogGateway.deleteImage(
                        resolvedProductId,
                        id,
                    );
                    if (!res.ok) {
                        showError(res.message);
                        return;
                    }
                    hideError();
                    renderImages(res.data, resolvedProductId);
                });
            },
        );
    }

    function escapeAttr(s: string): string {
        return s
            .replace(/&/g, "&amp;")
            .replace(/"/g, "&quot;")
            .replace(/</g, "&lt;");
    }

    async function init(resolvedProductId: string) {
        const boot = await bootAdminCatalogPage();
        if (boot === "env") {
            envAlert?.classList.remove("hidden");
            loading?.classList.add("hidden");
            return;
        }
        if (boot === "redirect") {
            return;
        }
        catalogGateway = boot.products;

        const initial = await catalogGateway.getById(resolvedProductId);
        if (!initial.ok) {
            loading?.classList.add("hidden");
            envAlert?.classList.remove("hidden");
            if (envAlert) {
                envAlert.textContent = initial.message;
            }
            return;
        }
        fillForm(initial.data);
        renderImages(initial.data, resolvedProductId);

        loading?.classList.add("hidden");
        shell?.classList.remove("hidden");

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            hideError();
            const titleEl = document.getElementById("field-title");
            const priceEl = document.getElementById("field-price");
            const stockEl = document.getElementById("field-stock");
            const descEl = document.getElementById("field-description");
            const contentEl = document.getElementById("field-content");
            const charEl = document.getElementById("field-characteristics");
            const activeEl = document.getElementById("field-active");
            if (
                !(titleEl instanceof HTMLInputElement) ||
                !(priceEl instanceof HTMLInputElement)
            ) {
                return;
            }
            const price = Number(priceEl.value);
            if (!Number.isFinite(price)) {
                showError("Introduce un precio numérico válido.");
                return;
            }
            let characteristics: Record<string, unknown> | undefined;
            if (charEl instanceof HTMLTextAreaElement && charEl.value.trim()) {
                try {
                    characteristics = parseCharacteristics(charEl.value);
                } catch (err) {
                    showError(
                        err instanceof Error
                            ? err.message
                            : "JSON de características inválido.",
                    );
                    return;
                }
            }
            const stockRaw =
                stockEl instanceof HTMLInputElement ? stockEl.value.trim() : "";
            const stock =
                stockRaw === "" ? undefined : Number(stockRaw);
            if (stock !== undefined && !Number.isFinite(stock)) {
                showError("Stock inválido.");
                return;
            }
            if (saveBtn instanceof HTMLButtonElement) {
                saveBtn.disabled = true;
                saveBtn.classList.add("btn-loading");
            }
            const result = await catalogGateway.update(resolvedProductId, {
                title: titleEl.value.trim(),
                price,
                ...(descEl instanceof HTMLTextAreaElement
                    ? { description: descEl.value.trim() || undefined }
                    : {}),
                ...(contentEl instanceof HTMLTextAreaElement
                    ? { content: contentEl.value.trim() || undefined }
                    : {}),
                ...(characteristics ? { characteristics } : {}),
                ...(stock !== undefined ? { stock } : {}),
                isActive:
                    activeEl instanceof HTMLInputElement
                        ? activeEl.checked
                        : undefined,
            });
            if (saveBtn instanceof HTMLButtonElement) {
                saveBtn.disabled = false;
                saveBtn.classList.remove("btn-loading");
            }
            if (!result.ok) {
                showError(result.message);
                return;
            }
            fillForm(result.data);
            renderImages(result.data, resolvedProductId);
        });

        archiveBtn?.addEventListener("click", async () => {
            if (
                !confirm(
                    "¿Archivar este producto? Se desactivará en catálogo y en Stripe.",
                )
            ) {
                return;
            }
            hideError();
            const res = await catalogGateway.remove(resolvedProductId);
            if (!res.ok) {
                showError(res.message);
                return;
            }
            window.location.assign("/admin/productos");
        });

        imageFile?.addEventListener("change", async () => {
            if (!(imageFile instanceof HTMLInputElement) || !imageFile.files?.[0]) {
                return;
            }
            const file = imageFile.files[0];
            hideError();
            const res = await catalogGateway.uploadImage(
                resolvedProductId,
                file,
            );
            imageFile.value = "";
            if (!res.ok) {
                showError(res.message);
                return;
            }
            renderImages(res.data, resolvedProductId);
        });
    }

    if (productId) {
        void init(productId);
    } else {
        window.location.assign("/admin/productos");
    }
</script>
