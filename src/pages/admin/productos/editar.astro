---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Editar producto — Administración">
    <div
        id="admin-env-alert"
        class="alert alert-warning mb-6 hidden"
        role="alert"
    >
        Configura <code class="text-xs">PUBLIC_API_URL</code> para editar
        productos.
    </div>

    <div id="admin-loading" class="flex flex-col items-center py-20 gap-4">
        <span class="loading loading-spinner loading-lg text-amber-600"
        ></span>
        <p class="text-sm text-neutral-500 font-inter">Cargando producto…</p>
    </div>

    <div id="admin-shell" class="hidden space-y-8 max-w-3xl">
        <div>
            <a
                href="/admin/productos"
                class="link link-hover text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4 inline-block"
            >
                ← Volver al listado
            </a>
            <h1
                class="text-2xl md:text-3xl font-montserrat font-bold text-neutral-900"
            >
                Editar producto
            </h1>
            <p class="text-sm text-neutral-500 mt-1">
                <code class="text-xs bg-neutral-100 px-1 rounded"
                    >PATCH /api/v1/products/:id</code
                >
                · imágenes vía
                <code class="text-xs bg-neutral-100 px-1 rounded"
                    >/images</code
                >
            </p>
        </div>

        <form
            id="product-edit-form"
            class="bg-white border border-neutral-100 rounded-2xl p-6 md:p-8 shadow-sm space-y-5"
        >
            <input type="hidden" id="field-id" value="" />

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-title">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Título</span
                    >
                </label>
                <input
                    id="field-title"
                    name="title"
                    required
                    class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                    aria-describedby="field-title-error"
                />
                <p
                    id="field-title-error"
                    class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                    role="alert"
                >
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-price">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Precio</span
                        >
                    </label>
                    <input
                        id="field-price"
                        name="price"
                        type="number"
                        step="0.01"
                        min="0"
                        required
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                        aria-describedby="field-price-error"
                    />
                    <p
                        id="field-price-error"
                        class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                        role="alert"
                    >
                    </p>
                </div>
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-stock">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Stock</span
                        >
                    </label>
                    <input
                        id="field-stock"
                        name="stock"
                        type="number"
                        step="1"
                        min="0"
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                        aria-describedby="field-stock-error"
                    />
                    <p
                        id="field-stock-error"
                        class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                        role="alert"
                    >
                    </p>
                </div>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-slug">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Slug (solo lectura)</span
                    >
                </label>
                <input
                    id="field-slug"
                    name="slug"
                    readonly
                    class="input input-bordered w-full bg-neutral-100 border-neutral-200 text-neutral-500"
                />
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-description">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Descripción</span
                    >
                </label>
                <textarea
                    id="field-description"
                    name="description"
                    rows="3"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-sm"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-content">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Contenido</span
                    >
                </label>
                <textarea
                    id="field-content"
                    name="content"
                    rows="5"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 font-mono text-xs"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-characteristics">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Características</span
                    >
                </label>
                <textarea
                    id="field-characteristics"
                    name="characteristics"
                    rows="4"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-sm"
                    placeholder="Texto libre: medidas, materiales, normas…"
                    aria-describedby="field-characteristics-error"
                ></textarea>
                <p
                    id="field-characteristics-error"
                    class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                    role="alert"
                >
                </p>
            </div>

            <label
                class="label cursor-pointer justify-start gap-3 border border-neutral-100 rounded-xl px-4 py-3 bg-neutral-50"
            >
                <input
                    id="field-active"
                    name="isActive"
                    type="checkbox"
                    class="checkbox checkbox-sm checkbox-neutral"
                />
                <span class="label-text text-sm text-neutral-600"
                    >Producto activo en catálogo</span
                >
            </label>

            <p
                id="field-form-error"
                class="text-error text-sm hidden whitespace-pre-line"
                role="alert"
            >
            </p>

            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <button
                    type="submit"
                    id="btn-save"
                    class="btn btn-neutral rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] h-12 flex-1 hover:bg-amber-600"
                >
                    Guardar cambios
                </button>
                <button
                    type="button"
                    id="btn-archive"
                    class="btn btn-outline btn-error rounded-xl h-12 font-inter font-semibold border-error/40"
                >
                    Archivar
                </button>
            </div>
        </form>

        <section
            id="remote-images-panel"
            class="bg-base-100 border border-base-200 rounded-2xl p-6 md:p-8 shadow-sm space-y-4"
        >
            <div
                class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3"
            >
                <div>
                    <h2 class="font-montserrat font-bold text-lg text-neutral-900">
                        Imágenes
                    </h2>
                    <p class="text-xs text-base-content/60 mt-1 max-w-lg">
                        Máx. 8 en catálogo · 5&nbsp;MB c/u · JPEG, PNG o WebP.
                        Puedes soltar varias a la vez; se suben en orden.
                    </p>
                </div>
                <div
                    id="remote-images-count-badge"
                    class="badge badge-neutral badge-lg font-mono text-xs shrink-0"
                >
                    0 / 8
                </div>
            </div>

            <div
                id="editar-upload-hint"
                class="alert alert-info text-sm py-2 hidden whitespace-pre-line"
                role="status"
            >
            </div>

            <p
                id="editar-images-error"
                class="text-error text-xs hidden whitespace-pre-line"
                role="alert"
            >
            </p>

            <label
                id="editar-image-drop-zone"
                for="image-file"
                class="block cursor-pointer rounded-box border-2 border-dashed border-base-300 bg-base-200/25 px-4 py-8 text-center transition-all hover:border-amber-500/55 hover:bg-amber-500/5 focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-500/25 outline-none"
            >
                <input
                    id="image-file"
                    type="file"
                    accept="image/jpeg,image/png,image/webp"
                    multiple
                    class="hidden"
                />
                <span
                    class="font-montserrat font-semibold text-sm text-neutral-800"
                >
                    Añadir imágenes
                </span>
                <span class="block text-xs text-base-content/60 mt-2">
                    Arrastra aquí o pulsa para elegir (varios archivos)
                </span>
            </label>

            <div
                id="images-list"
                class="grid gap-4 sm:grid-cols-2"
            >
            </div>
        </section>
    </div>
</AdminLayout>

<script>
    import { deleteProductImage } from "../../../catalog/application/delete-product-image.use-case";
    import { setMainProductImage } from "../../../catalog/application/set-main-product-image.use-case";
    import { uploadProductImage } from "../../../catalog/application/upload-product-image.use-case";
    import {
        setHelperLineError,
        setInlineFieldError,
    } from "../../../catalog/client/admin-inline-field-error";
    import { bootAdminCatalogPage } from "../../../catalog/client/boot-admin-catalog-page";
    import { classifyFilesForStaging } from "../../../catalog/client/stage-local-product-images";
    import type { CatalogProduct } from "../../../catalog/domain/product";
    import { PRODUCT_IMAGES_MAX_COUNT } from "../../../catalog/domain/product-image-upload";
    import type { ProductsGatewayPort } from "../../../catalog/ports/products-gateway.port";

    const productId =
        new URLSearchParams(window.location.search).get("id")?.trim() ?? "";

    const envAlert = document.getElementById("admin-env-alert");
    const loading = document.getElementById("admin-loading");
    const shell = document.getElementById("admin-shell");
    const form = document.getElementById("product-edit-form");
    const saveBtn = document.getElementById("btn-save");
    const archiveBtn = document.getElementById("btn-archive");
    const imagesList = document.getElementById("images-list");
    const imageFile = document.getElementById("image-file");
    const fieldId = document.getElementById("field-id");
    const remoteImagesPanel = document.getElementById("remote-images-panel");
    const editarDropZone = document.getElementById("editar-image-drop-zone");
    const remoteImagesBadge = document.getElementById("remote-images-count-badge");
    const editarUploadHint = document.getElementById("editar-upload-hint");

    let remoteImageCount = 0;

    const saveFieldIds = [
        "field-title",
        "field-price",
        "field-stock",
        "field-characteristics",
    ] as const;

    function clearInlineSaveErrors() {
        for (const id of saveFieldIds) {
            setInlineFieldError(id, null);
        }
    }

    function clearSaveFooterError() {
        setHelperLineError("field-form-error", null);
    }

    function clearImagesSectionError() {
        setHelperLineError("editar-images-error", null);
    }

    function showSaveFooterError(message: string) {
        hideEditarUploadHint();
        clearImagesSectionError();
        setHelperLineError("field-form-error", message);
    }

    function showImagesSectionError(message: string) {
        hideEditarUploadHint();
        clearSaveFooterError();
        setHelperLineError("editar-images-error", message);
    }

    function hideError() {
        clearInlineSaveErrors();
        clearSaveFooterError();
        clearImagesSectionError();
    }

    function hideEditarUploadHint() {
        editarUploadHint?.classList.add("hidden");
    }

    function showEditarUploadHint(message: string) {
        if (!editarUploadHint) {
            return;
        }
        editarUploadHint.textContent = message;
        editarUploadHint.classList.remove("hidden");
    }

    function setRemoteImagesBusy(busy: boolean) {
        remoteImagesPanel?.classList.toggle("opacity-60", busy);
        remoteImagesPanel?.classList.toggle("pointer-events-none", busy);
    }

    let catalogGateway!: ProductsGatewayPort;

    function fillForm(p: CatalogProduct) {
        const titleEl = document.getElementById("field-title");
        const priceEl = document.getElementById("field-price");
        const stockEl = document.getElementById("field-stock");
        const slugEl = document.getElementById("field-slug");
        const descEl = document.getElementById("field-description");
        const contentEl = document.getElementById("field-content");
        const charEl = document.getElementById("field-characteristics");
        const activeEl = document.getElementById("field-active");
        if (fieldId instanceof HTMLInputElement) {
            fieldId.value = p.id;
        }
        if (titleEl instanceof HTMLInputElement) {
            titleEl.value = p.title;
        }
        if (priceEl instanceof HTMLInputElement) {
            priceEl.value = String(p.price);
        }
        if (stockEl instanceof HTMLInputElement) {
            stockEl.value =
                p.stock === null || p.stock === undefined ? "" : String(p.stock);
        }
        if (slugEl instanceof HTMLInputElement) {
            slugEl.value = p.slug;
        }
        if (descEl instanceof HTMLTextAreaElement) {
            descEl.value = p.description ?? "";
        }
        if (contentEl instanceof HTMLTextAreaElement) {
            contentEl.value = p.content ?? "";
        }
        if (charEl instanceof HTMLTextAreaElement) {
            charEl.value = p.characteristics ?? "";
        }
        if (activeEl instanceof HTMLInputElement) {
            activeEl.checked = p.isActive;
        }
    }

    function renderImages(
        p: CatalogProduct,
        resolvedProductId: string,
    ) {
        if (!imagesList) {
            return;
        }
        remoteImageCount = p.images.length;
        if (remoteImagesBadge) {
            remoteImagesBadge.textContent = `${remoteImageCount} / ${PRODUCT_IMAGES_MAX_COUNT}`;
        }
        imagesList.innerHTML = "";
        if (p.images.length === 0) {
            const pEl = document.createElement("div");
            pEl.className =
                "rounded-box border border-dashed border-base-300 bg-base-200/25 py-12 text-center text-sm text-base-content/55 col-span-full font-inter";
            pEl.textContent = "Aún no hay imágenes en este producto.";
            imagesList.appendChild(pEl);
            return;
        }
        for (const img of p.images) {
            const card = document.createElement("article");
            card.className =
                "card lg:card-side bg-base-100 border border-base-200 shadow-sm overflow-hidden";
            card.dataset.imageCard = "";
            const mainLabel = img.isMain
                ? '<span class="badge badge-warning badge-sm font-semibold">Principal</span>'
                : '<span class="badge badge-ghost badge-sm border border-base-300">Secundaria</span>';
            card.innerHTML = `
        <figure class="w-full sm:w-40 shrink-0 bg-base-300 aspect-[4/3] sm:min-h-36">
          <img src="${escapeAttr(img.url)}" alt="" class="h-full w-full object-cover" loading="lazy" />
        </figure>
        <div class="card-body p-4 gap-3 justify-center">
          <div class="flex flex-wrap items-center gap-2">${mainLabel}</div>
          <div class="card-actions flex-wrap justify-end gap-2 sm:mt-0">
            <button type="button" class="btn btn-sm btn-outline border-base-300 rounded-xl" data-main="${escapeAttr(img.id)}">Marcar principal</button>
            <button type="button" class="btn btn-sm btn-outline btn-error rounded-xl" data-del="${escapeAttr(img.id)}">Eliminar</button>
          </div>
        </div>`;
            imagesList.appendChild(card);
        }

        imagesList.querySelectorAll<HTMLButtonElement>("button[data-main]").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const id = btn.dataset.main;
                    if (!id) {
                        return;
                    }
                    const res = await setMainProductImage(
                        catalogGateway,
                        resolvedProductId,
                        id,
                    );
                    if (!res.ok) {
                        showImagesSectionError(res.message);
                        return;
                    }
                    clearImagesSectionError();
                    renderImages(res.data, resolvedProductId);
                });
            },
        );

        imagesList.querySelectorAll<HTMLButtonElement>("button[data-del]").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const id = btn.dataset.del;
                    if (!id) {
                        return;
                    }
                    if (!confirm("¿Eliminar esta imagen del producto?")) {
                        return;
                    }
                    const res = await deleteProductImage(
                        catalogGateway,
                        resolvedProductId,
                        id,
                    );
                    if (!res.ok) {
                        showImagesSectionError(res.message);
                        return;
                    }
                    clearImagesSectionError();
                    renderImages(res.data, resolvedProductId);
                });
            },
        );
    }

    function escapeAttr(s: string): string {
        return s
            .replace(/&/g, "&amp;")
            .replace(/"/g, "&quot;")
            .replace(/</g, "&lt;");
    }

    async function init(resolvedProductId: string) {
        const boot = await bootAdminCatalogPage();
        if (boot === "env") {
            envAlert?.classList.remove("hidden");
            loading?.classList.add("hidden");
            return;
        }
        if (boot === "redirect") {
            return;
        }
        catalogGateway = boot.products;

        const initial = await catalogGateway.getById(resolvedProductId);
        if (!initial.ok) {
            loading?.classList.add("hidden");
            envAlert?.classList.remove("hidden");
            if (envAlert) {
                envAlert.textContent = initial.message;
            }
            return;
        }
        fillForm(initial.data);
        renderImages(initial.data, resolvedProductId);

        loading?.classList.add("hidden");
        shell?.classList.remove("hidden");

        for (const fieldId of saveFieldIds) {
            document.getElementById(fieldId)?.addEventListener("input", () => {
                setInlineFieldError(fieldId, null);
            });
        }

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            clearInlineSaveErrors();
            clearSaveFooterError();
            clearImagesSectionError();
            hideEditarUploadHint();
            const titleEl = document.getElementById("field-title");
            const priceEl = document.getElementById("field-price");
            const stockEl = document.getElementById("field-stock");
            const descEl = document.getElementById("field-description");
            const contentEl = document.getElementById("field-content");
            const charEl = document.getElementById("field-characteristics");
            const activeEl = document.getElementById("field-active");
            if (
                !(titleEl instanceof HTMLInputElement) ||
                !(priceEl instanceof HTMLInputElement)
            ) {
                return;
            }
            const titleTrim = titleEl.value.trim();
            if (!titleTrim) {
                setInlineFieldError(
                    "field-title",
                    "Escribe un título para el producto.",
                );
                return;
            }
            const price = Number(priceEl.value);
            if (!Number.isFinite(price)) {
                setInlineFieldError(
                    "field-price",
                    "Introduce un precio numérico válido.",
                );
                return;
            }
            const stockRaw =
                stockEl instanceof HTMLInputElement ? stockEl.value.trim() : "";
            const stock =
                stockRaw === "" ? undefined : Number(stockRaw);
            if (stock !== undefined && !Number.isFinite(stock)) {
                setInlineFieldError("field-stock", "Stock inválido.");
                return;
            }
            if (saveBtn instanceof HTMLButtonElement) {
                saveBtn.disabled = true;
                saveBtn.classList.add("btn-loading");
            }
            const result = await catalogGateway.update(resolvedProductId, {
                title: titleTrim,
                price,
                ...(descEl instanceof HTMLTextAreaElement
                    ? { description: descEl.value.trim() || undefined }
                    : {}),
                ...(contentEl instanceof HTMLTextAreaElement
                    ? { content: contentEl.value.trim() || undefined }
                    : {}),
                ...(charEl instanceof HTMLTextAreaElement
                    ? { characteristics: charEl.value.trim() }
                    : {}),
                ...(stock !== undefined ? { stock } : {}),
                isActive:
                    activeEl instanceof HTMLInputElement
                        ? activeEl.checked
                        : undefined,
            });
            if (saveBtn instanceof HTMLButtonElement) {
                saveBtn.disabled = false;
                saveBtn.classList.remove("btn-loading");
            }
            if (!result.ok) {
                showSaveFooterError(result.message);
                return;
            }
            hideError();
            fillForm(result.data);
            renderImages(result.data, resolvedProductId);
        });

        archiveBtn?.addEventListener("click", async () => {
            if (
                !confirm(
                    "¿Archivar este producto? Se desactivará en catálogo y en Stripe.",
                )
            ) {
                return;
            }
            hideError();
            const res = await catalogGateway.remove(resolvedProductId);
            if (!res.ok) {
                showSaveFooterError(res.message);
                return;
            }
            window.location.assign("/admin/productos");
        });

        async function handlePickedImageFiles(files: File[]) {
            if (!(imageFile instanceof HTMLInputElement) || files.length === 0) {
                return;
            }
            const classified = classifyFilesForStaging(remoteImageCount, files);
            const toUpload = classified
                .filter((c): c is { ok: true; file: File } => c.ok)
                .map((c) => c.file);
            const rejected = classified.filter((c) => !c.ok);
            if (rejected.length > 0) {
                const msg = rejected
                    .map((r) => `${r.name}: ${r.reason}`)
                    .join("\n");
                if (toUpload.length > 0) {
                    clearSaveFooterError();
                    clearInlineSaveErrors();
                    clearImagesSectionError();
                    showEditarUploadHint(msg);
                } else {
                    hideEditarUploadHint();
                    showImagesSectionError(msg);
                }
            } else {
                hideEditarUploadHint();
                clearImagesSectionError();
            }
            imageFile.value = "";
            if (toUpload.length === 0) {
                return;
            }
            clearSaveFooterError();
            clearInlineSaveErrors();
            try {
                imageFile.disabled = true;
                setRemoteImagesBusy(true);
                for (const file of toUpload) {
                    const res = await uploadProductImage(
                        catalogGateway,
                        resolvedProductId,
                        file,
                    );
                    if (!res.ok) {
                        showImagesSectionError(res.message);
                        break;
                    }
                    clearImagesSectionError();
                    renderImages(res.data, resolvedProductId);
                }
            } finally {
                imageFile.disabled = false;
                setRemoteImagesBusy(false);
            }
        }

        imageFile?.addEventListener("change", () => {
            if (!(imageFile instanceof HTMLInputElement) || !imageFile.files?.length) {
                return;
            }
            void handlePickedImageFiles(Array.from(imageFile.files));
        });

        editarDropZone?.addEventListener("dragover", (e) => {
            e.preventDefault();
            editarDropZone.classList.add("border-amber-500", "bg-amber-500/10");
        });
        editarDropZone?.addEventListener("dragleave", () => {
            editarDropZone.classList.remove("border-amber-500", "bg-amber-500/10");
        });
        editarDropZone?.addEventListener("drop", (e) => {
            e.preventDefault();
            editarDropZone.classList.remove("border-amber-500", "bg-amber-500/10");
            const dt = e.dataTransfer;
            if (!dt?.files?.length) {
                return;
            }
            void handlePickedImageFiles(Array.from(dt.files));
        });
    }

    if (productId) {
        void init(productId);
    } else {
        window.location.assign("/admin/productos");
    }
</script>
