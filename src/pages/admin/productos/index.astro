---
export const prerender = true;

import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Productos — Administración">
    <div
        id="admin-env-alert"
        class="alert alert-warning mb-6 hidden"
        role="alert"
    >
        Configura <code class="text-xs">PUBLIC_API_URL</code> en el front y
        asegúrate de que el API exponga <code class="text-xs"
            >/api/v1/products</code
        > (Stripe + S3 en el servidor).
    </div>

    <div id="admin-loading" class="flex flex-col items-center py-20 gap-4">
        <span class="loading loading-spinner loading-lg text-amber-600"
        ></span>
        <p class="text-sm text-neutral-500 font-inter">
            Comprobando permisos de administración…
        </p>
    </div>

    <div id="admin-shell" class="hidden space-y-8">
        <div
            class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4"
        >
            <div>
                <p
                    class="text-[10px] uppercase tracking-[0.35em] text-amber-600 font-bold mb-2"
                >
                    Catálogo
                </p>
                <h1
                    class="text-2xl md:text-3xl font-montserrat font-bold text-neutral-900"
                >
                    Productos
                </h1>
                <p class="text-sm text-neutral-500 mt-1 max-w-xl">
                    Listado paginado vía <code class="text-xs bg-neutral-100 px-1 rounded"
                        >GET /api/v1/products</code
                    >. Las mutaciones requieren sesión con rol
                    <code class="text-xs">admin</code>.
                </p>
            </div>
            <a
                href="/admin/productos/nuevo"
                class="btn btn-neutral rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] h-12 px-6 hover:bg-amber-600"
            >
                Nuevo producto
            </a>
        </div>

        <div
            id="admin-list-error"
            class="alert alert-error text-sm hidden"
            role="alert"
        >
        </div>

        <div
            class="bg-white border border-neutral-100 rounded-2xl p-5 md:p-6 shadow-sm"
        >
            <form
                id="admin-filter-form"
                class="flex flex-col lg:flex-row lg:items-end gap-4"
            >
                <div class="form-control flex-1 w-full">
                    <label class="label pt-0 pb-1" for="admin-q">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Buscar</span
                        >
                    </label>
                    <input
                        id="admin-q"
                        name="q"
                        type="search"
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                        placeholder="Título o descripción"
                    />
                </div>
                <label
                    class="label cursor-pointer justify-start gap-3 border border-neutral-100 rounded-xl px-4 py-3 bg-neutral-50"
                >
                    <input
                        id="admin-include-inactive"
                        type="checkbox"
                        class="checkbox checkbox-sm checkbox-neutral"
                    />
                    <span class="label-text text-sm text-neutral-600"
                        >Incluir inactivos</span
                    >
                </label>
                <button
                    type="submit"
                    class="btn btn-outline border-neutral-200 rounded-xl"
                >
                    Aplicar
                </button>
            </form>
        </div>

        <div
            class="bg-white border border-neutral-100 rounded-2xl overflow-hidden shadow-sm"
        >
            <div id="admin-products-table-wrap">
                <div class="overflow-x-auto">
                    <table class="table table-zebra">
                        <thead
                            class="bg-neutral-50 text-[10px] uppercase tracking-widest text-neutral-500"
                        >
                            <tr>
                                <th>Título</th>
                                <th>Slug</th>
                                <th class="text-right">Precio</th>
                                <th class="text-right">Stock</th>
                                <th>Estado</th>
                                <th class="text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="admin-products-tbody">
                        </tbody>
                    </table>
                </div>
                <div
                    class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-4 py-4 border-t border-neutral-100 bg-neutral-50/80"
                >
                    <p
                        id="admin-pagination-summary"
                        class="text-xs text-neutral-500 font-inter"
                    >
                    </p>
                    <div class="join">
                        <button
                            type="button"
                            id="admin-page-prev"
                            class="btn btn-sm join-item rounded-l-xl"
                        >
                            Anterior
                        </button>
                        <button
                            type="button"
                            id="admin-page-next"
                            class="btn btn-sm join-item rounded-r-xl"
                        >
                            Siguiente
                        </button>
                    </div>
                </div>
            </div>
            <div
                id="admin-empty-catalog"
                class="hidden text-center py-16 px-6 border-t border-neutral-100"
            >
                <p class="font-montserrat font-bold text-neutral-800">
                    No hay productos para mostrar
                </p>
                <p class="text-sm text-neutral-500 mt-2 font-inter max-w-md mx-auto">
                    Si acabas de eliminar o archivar productos, el listado puede quedar
                    vacío. Crea uno nuevo o cambia la búsqueda y el filtro de
                    inactivos.
                </p>
                <a
                    href="/admin/productos/nuevo"
                    class="btn btn-neutral rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] h-11 px-6 hover:bg-amber-600 mt-6"
                >
                    Nuevo producto
                </a>
            </div>
        </div>

        <dialog
            id="delete-product-modal"
            class="modal modal-middle"
            aria-labelledby="delete-product-modal-title"
        >
            <div
                class="modal-box rounded-2xl border border-neutral-200 bg-white shadow-2xl max-w-md w-[calc(100%-2rem)] p-6 sm:p-8"
            >
                <h3
                    id="delete-product-modal-title"
                    class="font-montserrat font-bold text-lg text-neutral-900 tracking-tight"
                >
                    Eliminar producto
                </h3>
                <p
                    class="mt-3 text-sm text-neutral-600 font-inter leading-relaxed"
                >
                    ¿Eliminar este producto del catálogo activo? Se desactivará
                    (baja lógica) y se archivará en Stripe.
                </p>
                <div
                    class="modal-action mt-6 flex-col-reverse sm:flex-row gap-2 sm:justify-end"
                >
                    <form method="dialog" class="w-full sm:w-auto m-0">
                        <button
                            type="submit"
                            class="btn btn-outline border-neutral-200 text-neutral-700 rounded-xl h-11 min-h-11 w-full sm:w-auto font-inter font-semibold"
                        >
                            Cancelar
                        </button>
                    </form>
                    <button
                        type="button"
                        id="delete-product-confirm"
                        class="btn btn-error rounded-xl h-11 min-h-11 w-full sm:w-auto text-white font-montserrat font-bold tracking-widest text-[11px] px-6"
                    >
                        Eliminar
                    </button>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop bg-neutral-900/50">
                <button
                    type="submit"
                    class="cursor-default min-h-full w-full opacity-0"
                    aria-label="Cerrar"
                >
                    close
                </button>
            </form>
        </dialog>
    </div>
</AdminLayout>

<script>
    import { deleteCatalogProduct } from "../../../catalog/application/delete-catalog-product.use-case";
    import { bootAdminCatalogPage } from "../../../catalog/client/boot-admin-catalog-page";
    import type { CatalogProduct } from "../../../catalog/domain/product";
    import type { ProductsGatewayPort } from "../../../catalog/ports/products-gateway.port";
    import { buildTruncatableHtmlFragment } from "../../../presentation/ui/truncatable-text";

    const envAlert = document.getElementById("admin-env-alert");
    const loading = document.getElementById("admin-loading");
    const shell = document.getElementById("admin-shell");
    const tbody = document.getElementById("admin-products-tbody");
    const summary = document.getElementById("admin-pagination-summary");
    const errBox = document.getElementById("admin-list-error");
    const form = document.getElementById("admin-filter-form");
    const qInput = document.getElementById("admin-q");
    const includeInactive = document.getElementById(
        "admin-include-inactive",
    );
    const btnPrev = document.getElementById("admin-page-prev");
    const btnNext = document.getElementById("admin-page-next");
    const tableWrap = document.getElementById("admin-products-table-wrap");
    const emptyCatalog = document.getElementById("admin-empty-catalog");
    const deleteProductModal = document.getElementById("delete-product-modal");
    const deleteProductConfirm = document.getElementById(
        "delete-product-confirm",
    );

    let page = 1;
    let pendingDeleteProductId: string | null = null;
    const pageSize = 10;

    function showListError(message: string) {
        if (!errBox) {
            return;
        }
        errBox.textContent = message;
        errBox.classList.remove("hidden");
    }

    function hideListError() {
        errBox?.classList.add("hidden");
    }

    function formatMoney(value: number): string {
        return value.toLocaleString("es-MX", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
        });
    }

    function renderRows(items: CatalogProduct[]) {
        if (!tbody) {
            return;
        }
        tbody.innerHTML = "";
        for (const p of items) {
            const tr = document.createElement("tr");
            tr.innerHTML = `
        <td class="max-w-[220px] align-top py-3">${buildTruncatableHtmlFragment({
            text: p.title,
            lines: 2,
            innerExtraClass: "font-medium text-neutral-800",
        })}</td>
        <td class="max-w-[180px] align-top py-3">${buildTruncatableHtmlFragment({
            text: p.slug,
            lines: 1,
            innerExtraClass: "text-xs text-neutral-500 font-mono",
        })}</td>
        <td class="text-right font-mono text-sm">${formatMoney(p.price)}</td>
        <td class="text-right text-sm">${p.stock ?? "—"}</td>
        <td>${p.isActive ? '<span class="badge badge-success badge-sm">Activo</span>' : '<span class="badge badge-ghost badge-sm">Inactivo</span>'}</td>
        <td class="text-right space-x-1 whitespace-nowrap">
          <a class="btn btn-ghost btn-xs rounded-lg" href="/admin/productos/editar?id=${encodeURIComponent(p.id)}">Editar</a>
          <button type="button" class="btn btn-ghost btn-xs text-error rounded-lg" data-delete-product="${encodeURIComponent(p.id)}">Eliminar</button>
        </td>`;
            tbody.appendChild(tr);
        }

        tbody.querySelectorAll<HTMLButtonElement>(
            "button[data-delete-product]",
        ).forEach((btn) => {
            btn.addEventListener("click", () => {
                const id = btn.dataset.deleteProduct;
                if (!id) {
                    return;
                }
                pendingDeleteProductId = id;
                hideListError();
                if (deleteProductModal instanceof HTMLDialogElement) {
                    deleteProductModal.showModal();
                }
            });
        });
    }

    let catalogGateway!: ProductsGatewayPort;

    async function loadPage() {
        hideListError();
        const q =
            qInput instanceof HTMLInputElement ? qInput.value.trim() : "";
        const inactive =
            includeInactive instanceof HTMLInputElement
                ? includeInactive.checked
                : false;
        const result = await catalogGateway.list({
            page,
            pageSize,
            ...(q ? { q } : {}),
            activeOnly: !inactive,
        });
        if (!result.ok) {
            showListError(result.message);
            if (tbody) {
                tbody.innerHTML = "";
            }
            tableWrap?.classList.remove("hidden");
            emptyCatalog?.classList.add("hidden");
            return;
        }
        const { items, pagination } = result.data;
        if (items.length === 0) {
            if (tbody) {
                tbody.innerHTML = "";
            }
            tableWrap?.classList.add("hidden");
            emptyCatalog?.classList.remove("hidden");
        } else {
            tableWrap?.classList.remove("hidden");
            emptyCatalog?.classList.add("hidden");
            renderRows(items);
        }
        if (summary) {
            summary.textContent = `Página ${pagination.page} de ${pagination.totalPages} · ${pagination.total} productos`;
        }
        if (btnPrev instanceof HTMLButtonElement) {
            btnPrev.disabled = pagination.page <= 1;
        }
        if (btnNext instanceof HTMLButtonElement) {
            btnNext.disabled = pagination.page >= pagination.totalPages;
        }
    }

    async function init() {
        const boot = await bootAdminCatalogPage();
        if (boot === "env") {
            envAlert?.classList.remove("hidden");
            loading?.classList.add("hidden");
            return;
        }
        if (boot === "redirect") {
            return;
        }
        catalogGateway = boot.products;
        loading?.classList.add("hidden");
        shell?.classList.remove("hidden");

        form?.addEventListener("submit", (e) => {
            e.preventDefault();
            page = 1;
            void loadPage();
        });
        btnPrev?.addEventListener("click", () => {
            if (page > 1) {
                page -= 1;
                void loadPage();
            }
        });
        btnNext?.addEventListener("click", () => {
            page += 1;
            void loadPage();
        });

        deleteProductModal?.addEventListener("close", () => {
            pendingDeleteProductId = null;
            if (deleteProductConfirm instanceof HTMLButtonElement) {
                deleteProductConfirm.disabled = false;
                deleteProductConfirm.classList.remove("btn-loading");
            }
        });

        deleteProductConfirm?.addEventListener("click", async () => {
            const id = pendingDeleteProductId;
            if (
                !id ||
                !(deleteProductModal instanceof HTMLDialogElement) ||
                !(deleteProductConfirm instanceof HTMLButtonElement)
            ) {
                return;
            }
            deleteProductConfirm.disabled = true;
            deleteProductConfirm.classList.add("btn-loading");
            try {
                hideListError();
                const result = await deleteCatalogProduct(catalogGateway, id);
                if (!result.ok) {
                    showListError(result.message);
                    deleteProductModal.close();
                    return;
                }
                deleteProductModal.close();
                await loadPage();
            } finally {
                deleteProductConfirm.disabled = false;
                deleteProductConfirm.classList.remove("btn-loading");
            }
        });

        await loadPage();
    }

    void init();
</script>
