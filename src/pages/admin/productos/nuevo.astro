---
export const prerender = true;

import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Nuevo producto — Administración">
    <div
        id="admin-env-alert"
        class="alert alert-warning mb-6 hidden"
        role="alert"
    >
        Configura <code class="text-xs">PUBLIC_API_URL</code> para crear
        productos contra el API.
    </div>

    <div id="admin-loading" class="flex flex-col items-center py-20 gap-4">
        <span class="loading loading-spinner loading-lg text-amber-600"
        ></span>
        <p class="text-sm text-neutral-500 font-inter">
            Comprobando permisos de administración…
        </p>
    </div>

    <div id="admin-shell" class="hidden space-y-8 max-w-3xl">
        <div>
            <a
                href="/admin/productos"
                class="link link-hover text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4 inline-block"
            >
                ← Volver al listado
            </a>
            <h1
                class="text-2xl md:text-3xl font-montserrat font-bold text-neutral-900"
            >
                Nuevo producto
            </h1>
            <p class="text-sm text-neutral-500 mt-1">
                Tras el alta se pueden subir imágenes con
                <code class="text-xs bg-neutral-100 px-1 rounded"
                    >POST .../products/:id/images</code
                >
                (o elige archivos aquí y se envían en secuencia).
            </p>
        </div>

        <div
            id="admin-form-warning"
            class="alert alert-warning text-sm hidden"
            role="status"
        >
            <p
                id="admin-form-warning-text"
                class="font-inter whitespace-pre-line"
            ></p>
            <p class="mt-2 mb-0">
                <a
                    id="admin-form-warning-link"
                    href="#"
                    class="link link-hover font-semibold text-neutral-800"
                    >Ir a la ficha del producto</a
                >
            </p>
        </div>

        <form
            id="product-create-form"
            class="bg-white border border-neutral-100 rounded-2xl p-6 md:p-8 shadow-sm space-y-5"
        >
            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-title">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Título</span
                    >
                </label>
                <input
                    id="field-title"
                    name="title"
                    required
                    class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                    placeholder="Nombre del producto"
                    aria-describedby="field-title-error"
                />
                <p
                    id="field-title-error"
                    class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                    role="alert"
                >
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-price">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Precio</span
                        >
                    </label>
                    <input
                        id="field-price"
                        name="price"
                        type="number"
                        step="0.01"
                        min="0"
                        required
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                        aria-describedby="field-price-error"
                    />
                    <p
                        id="field-price-error"
                        class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                        role="alert"
                    >
                    </p>
                </div>
                <div class="form-control w-full">
                    <label class="label pt-0 pb-1" for="field-stock">
                        <span
                            class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                            >Stock</span
                        >
                    </label>
                    <input
                        id="field-stock"
                        name="stock"
                        type="number"
                        step="1"
                        min="0"
                        class="input input-bordered w-full bg-neutral-50 border-neutral-200"
                        aria-describedby="field-stock-error"
                    />
                    <p
                        id="field-stock-error"
                        class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                        role="alert"
                    >
                    </p>
                </div>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-description">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Descripción</span
                    >
                </label>
                <textarea
                    id="field-description"
                    name="description"
                    rows="3"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-sm"
                    placeholder="Resumen corto"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-content">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Contenido</span
                    >
                </label>
                <textarea
                    id="field-content"
                    name="content"
                    rows="5"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 font-mono text-xs"
                    placeholder="Texto largo / fich técnica"
                ></textarea>
            </div>

            <div class="form-control w-full">
                <label class="label pt-0 pb-1" for="field-characteristics">
                    <span
                        class="label-text text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >Características</span
                    >
                </label>
                <textarea
                    id="field-characteristics"
                    name="characteristics"
                    rows="4"
                    class="textarea textarea-bordered w-full bg-neutral-50 border-neutral-200 text-sm"
                    placeholder="Ej. Potencia 12W, temperatura de color 3000K, IP44…"
                    aria-describedby="field-characteristics-error"
                ></textarea>
                <p
                    id="field-characteristics-error"
                    class="label text-error text-xs py-0 min-h-[1.25rem] hidden"
                    role="alert"
                >
                </p>
            </div>

            <div
                id="staged-images-panel"
                class="rounded-2xl border border-base-200 bg-base-100 p-4 md:p-6 shadow-sm space-y-4"
            >
                <div
                    class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3"
                >
                    <div class="space-y-1">
                        <p
                            class="text-[10px] font-bold uppercase tracking-widest text-neutral-400"
                        >
                            Imágenes (opcional)
                        </p>
                        <p class="text-xs text-base-content/60 max-w-md">
                            Hasta 8 archivos · máx. 5&nbsp;MB c/u · JPEG, PNG o WebP.
                            El orden se respeta; la primera suele ser la principal en
                            catálogo.
                        </p>
                    </div>
                    <div
                        id="staged-count-badge"
                        class="badge badge-neutral badge-lg gap-1 font-mono text-xs shrink-0"
                    >
                        0 / 8
                    </div>
                </div>

                <div
                    id="staged-pick-hint"
                    class="alert alert-info text-sm py-2 hidden whitespace-pre-line"
                    role="status"
                >
                </div>

                <p
                    id="staged-files-error"
                    class="text-error text-xs hidden whitespace-pre-line"
                    role="alert"
                >
                </p>

                <label
                    id="nuevo-image-drop-zone"
                    for="field-images"
                    class="block cursor-pointer rounded-box border-2 border-dashed border-base-300 bg-base-200/25 px-4 py-10 text-center transition-all hover:border-amber-500/55 hover:bg-amber-500/5 focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-500/25 outline-none"
                >
                    <input
                        id="field-images"
                        name="images"
                        type="file"
                        accept="image/jpeg,image/png,image/webp"
                        multiple
                        class="hidden"
                    />
                    <span
                        class="font-montserrat font-semibold text-sm text-neutral-800"
                    >
                        Arrastra imágenes aquí
                    </span>
                    <span
                        class="block text-xs text-base-content/60 mt-2"
                    >
                        o pulsa para elegir archivos de tu equipo
                    </span>
                </label>

                <p
                    id="staged-empty-hint"
                    class="text-center text-sm text-base-content/50 py-1"
                >
                    Sin imágenes en cola. Puedes crear el producto y añadirlas después.
                </p>

                <div
                    id="staged-images-grid"
                    class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 hidden"
                >
                </div>

                <div class="flex justify-end">
                    <button
                        type="button"
                        id="btn-clear-staged"
                        class="btn btn-ghost btn-sm rounded-xl hidden"
                    >
                        Quitar todas
                    </button>
                </div>
            </div>

            <label
                class="label cursor-pointer justify-start gap-3 border border-neutral-100 rounded-xl px-4 py-3 bg-neutral-50"
            >
                <input
                    id="field-active"
                    name="isActive"
                    type="checkbox"
                    class="checkbox checkbox-sm checkbox-neutral"
                    checked
                />
                <span class="label-text text-sm text-neutral-600"
                    >Producto activo en catálogo</span
                >
            </label>

            <p
                id="field-form-error"
                class="text-error text-sm hidden whitespace-pre-line"
                role="alert"
            >
            </p>

            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <button
                    type="submit"
                    id="btn-submit"
                    class="btn btn-neutral rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] h-12 flex-1 hover:bg-amber-600"
                >
                    Crear producto
                </button>
                <a
                    href="/admin/productos"
                    class="btn btn-ghost rounded-xl h-12 font-inter font-semibold"
                >
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</AdminLayout>

<script>
    import { createProductWithImages } from "../../../catalog/application/create-product-with-images.use-case";
    import {
        setHelperLineError,
        setInlineFieldError,
    } from "../../../catalog/client/admin-inline-field-error";
    import { bootAdminCatalogPage } from "../../../catalog/client/boot-admin-catalog-page";
    import { classifyFilesForStaging } from "../../../catalog/client/stage-local-product-images";
    import type { CatalogResult } from "../../../catalog/domain/catalog-result";
    import type { CreateProductWithImagesData } from "../../../catalog/application/create-product-with-images.use-case";
    import { PRODUCT_IMAGES_MAX_COUNT } from "../../../catalog/domain/product-image-upload";
    import type { ProductsGatewayPort } from "../../../catalog/ports/products-gateway.port";

    const envAlert = document.getElementById("admin-env-alert");
    const loading = document.getElementById("admin-loading");
    const shell = document.getElementById("admin-shell");
    const warnBox = document.getElementById("admin-form-warning");
    const warnText = document.getElementById("admin-form-warning-text");
    const warnLink = document.getElementById("admin-form-warning-link");
    const form = document.getElementById("product-create-form");
    const submitBtn = document.getElementById("btn-submit");
    const imagesInput = document.getElementById("field-images");
    const stagedPanel = document.getElementById("staged-images-panel");
    const dropZone = document.getElementById("nuevo-image-drop-zone");
    const stagedGrid = document.getElementById("staged-images-grid");
    const stagedEmpty = document.getElementById("staged-empty-hint");
    const stagedBadge = document.getElementById("staged-count-badge");
    const btnClearStaged = document.getElementById("btn-clear-staged");
    const stagedPickHint = document.getElementById("staged-pick-hint");

    type StagedEntry = { file: File; url: string };
    const staged: StagedEntry[] = [];

    function clearInlineAndFooterErrors() {
        for (const id of [
            "field-title",
            "field-price",
            "field-stock",
            "field-characteristics",
        ] as const) {
            setInlineFieldError(id, null);
        }
        setHelperLineError("field-form-error", null);
        setHelperLineError("staged-files-error", null);
    }

    function showFormFooterError(message: string) {
        warnBox?.classList.add("hidden");
        hideStagedPickHint();
        setHelperLineError("staged-files-error", null);
        setHelperLineError("field-form-error", message);
    }

    function showStagedFilesOnlyError(message: string) {
        hideStagedPickHint();
        setHelperLineError("field-form-error", null);
        setHelperLineError("staged-files-error", message);
    }

    function showWarning(message: string, editHref: string) {
        clearInlineAndFooterErrors();
        hideStagedPickHint();
        if (warnText) {
            warnText.textContent = message;
        }
        if (warnLink instanceof HTMLAnchorElement) {
            warnLink.href = editHref;
        }
        warnBox?.classList.remove("hidden");
    }

    function hideWarning() {
        warnBox?.classList.add("hidden");
    }

    function hideStagedPickHint() {
        stagedPickHint?.classList.add("hidden");
    }

    function showStagedPickHint(message: string) {
        if (!stagedPickHint) {
            return;
        }
        stagedPickHint.textContent = message;
        stagedPickHint.classList.remove("hidden");
    }

    function disposeStagedUrls() {
        for (const e of staged) {
            URL.revokeObjectURL(e.url);
        }
    }

    function updateStagedBadge() {
        if (stagedBadge) {
            stagedBadge.textContent = `${staged.length} / ${PRODUCT_IMAGES_MAX_COUNT}`;
        }
    }

    function setStagedUiBusy(busy: boolean) {
        if (stagedPanel) {
            stagedPanel.classList.toggle("opacity-60", busy);
            stagedPanel.classList.toggle("pointer-events-none", busy);
        }
    }

    function renderStagedGrid() {
        updateStagedBadge();
        if (!stagedGrid || !stagedEmpty || !btnClearStaged) {
            return;
        }
        if (staged.length === 0) {
            stagedGrid.classList.add("hidden");
            stagedGrid.replaceChildren();
            stagedEmpty.classList.remove("hidden");
            btnClearStaged.classList.add("hidden");
            return;
        }
        stagedEmpty.classList.add("hidden");
        stagedGrid.classList.remove("hidden");
        btnClearStaged.classList.remove("hidden");
        stagedGrid.replaceChildren();
        staged.forEach((entry, index) => {
            const card = document.createElement("article");
            card.className =
                "card card-compact bg-base-100 border border-base-200 shadow-sm overflow-hidden group";
            const figure = document.createElement("figure");
            figure.className =
                "relative aspect-square bg-base-300";
            const img = document.createElement("img");
            img.src = entry.url;
            img.alt = "";
            img.className = "h-full w-full object-cover";
            const removeBtn = document.createElement("button");
            removeBtn.type = "button";
            removeBtn.className =
                "btn btn-circle btn-xs btn-neutral text-base-100 absolute top-2 right-2 shadow-md opacity-90 hover:opacity-100";
            removeBtn.setAttribute("aria-label", "Quitar de la cola");
            removeBtn.textContent = "✕";
            removeBtn.addEventListener("click", (ev) => {
                ev.preventDefault();
                removeStagedAt(index);
            });
            figure.append(img, removeBtn);
            const body = document.createElement("div");
            body.className = "card-body p-2.5 gap-1";
            const nameEl = document.createElement("p");
            nameEl.className =
                "text-[11px] text-neutral-600 truncate font-inter";
            nameEl.textContent = entry.file.name;
            nameEl.title = entry.file.name;
            body.append(nameEl);
            card.append(figure, body);
            stagedGrid.appendChild(card);
        });
    }

    function removeStagedAt(index: number) {
        const entry = staged[index];
        if (!entry) {
            return;
        }
        URL.revokeObjectURL(entry.url);
        staged.splice(index, 1);
        renderStagedGrid();
    }

    function tryAddPickedFiles(files: File[]) {
        if (files.length === 0) {
            return;
        }
        const classified = classifyFilesForStaging(staged.length, files);
        const rejected = classified.filter((c) => !c.ok);
        const accepted = classified.filter(
            (c): c is { ok: true; file: File } => c.ok,
        );
        for (const c of accepted) {
            staged.push({ file: c.file, url: URL.createObjectURL(c.file) });
        }
        if (rejected.length > 0) {
            const msg = rejected.map((r) => `${r.name}: ${r.reason}`).join("\n");
            if (accepted.length > 0) {
                setHelperLineError("staged-files-error", null);
                showStagedPickHint(msg);
            } else {
                hideStagedPickHint();
                showStagedFilesOnlyError(msg);
            }
        } else {
            setHelperLineError("staged-files-error", null);
            hideStagedPickHint();
        }
        renderStagedGrid();
    }

    function clearAllStaged() {
        disposeStagedUrls();
        staged.length = 0;
        setHelperLineError("staged-files-error", null);
        hideStagedPickHint();
        renderStagedGrid();
    }

    let catalogGateway!: ProductsGatewayPort;

    async function init() {
        const boot = await bootAdminCatalogPage();
        if (boot === "env") {
            envAlert?.classList.remove("hidden");
            loading?.classList.add("hidden");
            return;
        }
        if (boot === "redirect") {
            return;
        }
        catalogGateway = boot.products;
        loading?.classList.add("hidden");
        shell?.classList.remove("hidden");

        renderStagedGrid();

        imagesInput?.addEventListener("change", () => {
            if (!(imagesInput instanceof HTMLInputElement) || !imagesInput.files?.length) {
                return;
            }
            tryAddPickedFiles(Array.from(imagesInput.files));
            imagesInput.value = "";
        });

        dropZone?.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropZone.classList.add("border-amber-500", "bg-amber-500/10");
        });
        dropZone?.addEventListener("dragleave", () => {
            dropZone.classList.remove("border-amber-500", "bg-amber-500/10");
        });
        dropZone?.addEventListener("drop", (e) => {
            e.preventDefault();
            dropZone.classList.remove("border-amber-500", "bg-amber-500/10");
            const dt = e.dataTransfer;
            if (!dt?.files?.length) {
                return;
            }
            tryAddPickedFiles(Array.from(dt.files));
        });

        btnClearStaged?.addEventListener("click", () => {
            clearAllStaged();
        });

        for (const fieldId of [
            "field-title",
            "field-price",
            "field-stock",
            "field-characteristics",
        ] as const) {
            document.getElementById(fieldId)?.addEventListener("input", () => {
                setInlineFieldError(fieldId, null);
            });
        }

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            clearInlineAndFooterErrors();
            hideWarning();
            hideStagedPickHint();
            const titleEl = document.getElementById("field-title");
            const priceEl = document.getElementById("field-price");
            const stockEl = document.getElementById("field-stock");
            const descEl = document.getElementById("field-description");
            const contentEl = document.getElementById("field-content");
            const charEl = document.getElementById("field-characteristics");
            const activeEl = document.getElementById("field-active");
            if (
                !(titleEl instanceof HTMLInputElement) ||
                !(priceEl instanceof HTMLInputElement)
            ) {
                return;
            }
            const titleTrim = titleEl.value.trim();
            if (!titleTrim) {
                setInlineFieldError(
                    "field-title",
                    "Escribe un título para el producto.",
                );
                return;
            }
            const price = Number(priceEl.value);
            if (!Number.isFinite(price)) {
                setInlineFieldError(
                    "field-price",
                    "Introduce un precio numérico válido.",
                );
                return;
            }
            const characteristicsText =
                charEl instanceof HTMLTextAreaElement
                    ? charEl.value.trim()
                    : "";
            const characteristics =
                characteristicsText === "" ? undefined : characteristicsText;
            const stockRaw =
                stockEl instanceof HTMLInputElement ? stockEl.value.trim() : "";
            const stock =
                stockRaw === "" ? undefined : Number(stockRaw);
            if (stock !== undefined && !Number.isFinite(stock)) {
                setInlineFieldError("field-stock", "Stock inválido.");
                return;
            }
            const imageFiles = staged.map((s) => s.file);

            if (submitBtn instanceof HTMLButtonElement) {
                submitBtn.disabled = true;
                submitBtn.classList.add("btn-loading");
            }
            setStagedUiBusy(true);
            if (imagesInput instanceof HTMLInputElement) {
                imagesInput.disabled = true;
            }
            let result: CatalogResult<CreateProductWithImagesData>;
            try {
                result = await createProductWithImages(
                    catalogGateway,
                    {
                        title: titleTrim,
                        price,
                        ...(descEl instanceof HTMLTextAreaElement &&
                        descEl.value.trim()
                            ? { description: descEl.value.trim() }
                            : {}),
                        ...(contentEl instanceof HTMLTextAreaElement &&
                        contentEl.value.trim()
                            ? { content: contentEl.value.trim() }
                            : {}),
                        ...(characteristics ? { characteristics } : {}),
                        ...(stock !== undefined ? { stock } : {}),
                        isActive:
                            activeEl instanceof HTMLInputElement
                                ? activeEl.checked
                                : true,
                    },
                    imageFiles,
                );
            } catch (err) {
                showFormFooterError(
                    err instanceof Error
                        ? err.message
                        : "No se pudo completar la operación.",
                );
                return;
            } finally {
                if (submitBtn instanceof HTMLButtonElement) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove("btn-loading");
                }
                setStagedUiBusy(false);
                if (imagesInput instanceof HTMLInputElement) {
                    imagesInput.disabled = false;
                }
            }
            if (!result.ok) {
                showFormFooterError(result.message);
                return;
            }
            const editHref = `/admin/productos/editar?id=${encodeURIComponent(result.data.product.id)}`;
            if (result.data.failedUploads.length > 0) {
                const lines = result.data.failedUploads.map(
                    (f) => `• ${f.name}: ${f.message}`,
                );
                showWarning(
                    `El producto se creó, pero no se subieron todas las imágenes.\n${lines.join("\n")}`,
                    editHref,
                );
                return;
            }
            window.location.assign(editHref);
        });
    }

    void init();
</script>
