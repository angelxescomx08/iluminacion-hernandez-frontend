---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import LoginForm from "../components/auth/LoginForm.astro";
---

<Layout title="Iniciar sesión | Iluminación Hernández">
    <main class="bg-[#FDFDFD] min-h-[calc(100dvh-74px)] py-12 px-6">
        <div class="max-w-md mx-auto">
            <div class="mb-10 border-l-4 border-amber-500 pl-6">
                <h1
                    class="text-2xl md:text-4xl font-montserrat font-black text-neutral-800 tracking-tight uppercase"
                >
                    Acceso
                </h1>
                <p class="text-neutral-500 mt-2 font-inter text-sm">
                    Iluminación Hernández
                </p>
            </div>
            <LoginForm />
        </div>
    </main>
</Layout>
