---
import { Picture } from "astro:assets";
// Import de prueba solicitado
import {
    images1,
    images2,
    images3,
    images4,
} from "../assets/images/lookbook-section/images";

/** Índices para duplicar la columna (tren superior + tren clon); el desplazamiento -50% es un período exacto. */
const MARQUEE_SEGMENTS = [0, 1] as const;
---

<section
    class="py-12 bg-white overflow-hidden"
    aria-label="Galería decorativa de ambientes iluminados"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
            <h2
                class="text-[10px] uppercase tracking-[0.5em] text-amber-600 font-bold mb-4"
            >
                Catálogo Visual
            </h2>
            <h3
                class="text-3xl md:text-5xl font-montserrat font-light text-neutral-900"
            >
                Flujo de <span class="italic font-serif">inspiración</span>.
            </h3>
        </div>

        <div class="relative h-[600px] md:h-[800px] overflow-hidden">
            <div class="lookbook-marquee-root grid grid-cols-2 md:grid-cols-4 gap-4 h-full">
                <div class="scroll-column up">
                    <div class="scroll-content">
                        {
                            MARQUEE_SEGMENTS.map((segment) => (
                                <div
                                    class="scroll-set"
                                    aria-hidden={segment === 1 ? "true" : undefined}
                                >
                                    {images1.map((img) => (
                                        <div class="item aspect-3/4">
                                            <Picture
                                                src={img}
                                                alt=""
                                                formats={["avif", "webp"]}
                                                widths={[400]}
                                                class="w-full h-full object-cover rounded-3xl"
                                                inferSize={true}
                                                loading="eager"
                                                decoding="async"
                                            />
                                        </div>
                                    ))}
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="scroll-column down">
                    <div class="scroll-content">
                        {
                            MARQUEE_SEGMENTS.map((segment) => (
                                <div
                                    class="scroll-set"
                                    aria-hidden={segment === 1 ? "true" : undefined}
                                >
                                    {images2.map((img) => (
                                        <div class="item aspect-square">
                                            <Picture
                                                src={img}
                                                alt=""
                                                formats={["avif", "webp"]}
                                                widths={[400]}
                                                class="w-full h-full object-cover rounded-3xl"
                                                inferSize={true}
                                                loading="eager"
                                                decoding="async"
                                            />
                                        </div>
                                    ))}
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="scroll-column up hidden md:flex">
                    <div class="scroll-content">
                        {
                            MARQUEE_SEGMENTS.map((segment) => (
                                <div
                                    class="scroll-set"
                                    aria-hidden={segment === 1 ? "true" : undefined}
                                >
                                    {images3.map((img) => (
                                        <div class="item aspect-4/5">
                                            <Picture
                                                src={img}
                                                alt=""
                                                formats={["avif", "webp"]}
                                                widths={[400]}
                                                class="w-full h-full object-cover rounded-3xl"
                                                inferSize={true}
                                                loading="eager"
                                                decoding="async"
                                            />
                                        </div>
                                    ))}
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="scroll-column down hidden md:flex">
                    <div class="scroll-content">
                        {
                            MARQUEE_SEGMENTS.map((segment) => (
                                <div
                                    class="scroll-set"
                                    aria-hidden={segment === 1 ? "true" : undefined}
                                >
                                    {images4.map((img) => (
                                        <div class="item aspect-2/3">
                                            <Picture
                                                src={img}
                                                alt=""
                                                formats={["avif", "webp"]}
                                                widths={[400]}
                                                class="w-full h-full object-cover rounded-3xl"
                                                inferSize={true}
                                                loading="eager"
                                                decoding="async"
                                            />
                                        </div>
                                    ))}
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .scroll-column {
        position: relative;
        height: 100%;
        min-height: 0;
        overflow: hidden;
        --duration: 40s;
    }

    .scroll-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
        will-change: transform;
        backface-visibility: hidden;
    }

    .scroll-set {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex-shrink: 0;
    }

    .item {
        width: 100%;
        flex-shrink: 0;
    }

    /*
     * Dos .scroll-set idénticos: la altura total es 2×bloque + 1rem entre bloques.
     * Desplazar exactamente la mitad (-50% - medio gap) alinea el clon con el original sin solapar a blanco.
     */
    @keyframes scrollUp {
        0% {
            transform: translate3d(0, 0, 0);
        }
        100% {
            transform: translate3d(0, calc(-50% - 0.5rem), 0);
        }
    }

    @keyframes scrollDown {
        0% {
            transform: translate3d(0, calc(-50% - 0.5rem), 0);
        }
        100% {
            transform: translate3d(0, 0, 0);
        }
    }

    .up .scroll-content {
        animation: scrollUp var(--duration) linear infinite;
    }

    .down .scroll-content {
        animation: scrollDown var(--duration) linear infinite;
    }

    .scroll-column:hover .scroll-content {
        animation-play-state: running;
    }

    @media (prefers-reduced-motion: reduce) {
        .up .scroll-content,
        .down .scroll-content {
            animation: none;
            transform: none;
        }
    }
</style>

<script>
    const PX_PER_SEC = 48;
    const MIN_SEC = 20;
    const MAX_SEC = 120;

    let marqueeResizeObserver: ResizeObserver | null = null;

    function syncLookbookMarqueeSpeed() {
        const root = document.querySelector(".lookbook-marquee-root");
        if (!root) return;

        root.querySelectorAll(".scroll-column").forEach((node) => {
            if (!(node instanceof HTMLElement)) return;

            const content = node.querySelector(".scroll-content");
            if (!(content instanceof HTMLElement)) return;

            const h = content.offsetHeight;
            if (h < 48) return;

            const loopPx = h * 0.5;
            const sec = Math.min(
                MAX_SEC,
                Math.max(MIN_SEC, loopPx / PX_PER_SEC),
            );
            node.style.setProperty("--duration", `${sec.toFixed(2)}s`);
        });
    }

    function bindLookbookMarqueeResizeObserver() {
        marqueeResizeObserver?.disconnect();
        const root = document.querySelector(".lookbook-marquee-root");
        if (!root) return;
        const observer = new ResizeObserver(() => syncLookbookMarqueeSpeed());
        marqueeResizeObserver = observer;
        root.querySelectorAll(".scroll-content").forEach((el) =>
            observer.observe(el),
        );
    }

    function initLookbookMarquee() {
        syncLookbookMarqueeSpeed();
        bindLookbookMarqueeResizeObserver();
    }

    let resizeDebounce = 0;
    window.addEventListener("resize", () => {
        window.clearTimeout(resizeDebounce);
        resizeDebounce = window.setTimeout(syncLookbookMarqueeSpeed, 120);
    });

    initLookbookMarquee();
    requestAnimationFrame(() => {
        syncLookbookMarqueeSpeed();
        requestAnimationFrame(syncLookbookMarqueeSpeed);
    });

    document.addEventListener("astro:page-load", initLookbookMarquee);
</script>
