---
// Header.astro — sesión reflejada en cliente vía GET /api/v1/auth/session
---

<header
    class="sticky top-0 z-100 w-full bg-white/90 backdrop-blur-xl border-b border-neutral-100/50"
>
    <p class="sr-only" aria-live="polite" data-session-live>
        Comprobando sesión…
    </p>

    <div class="drawer">
        <input id="main-drawer" type="checkbox" class="drawer-toggle" />

        <div class="drawer-content flex flex-col">
            <nav
                class="navbar max-w-7xl mx-auto h-20 sm:h-24 px-4 sm:px-8 flex justify-between items-center w-full"
                aria-label="Navegación principal"
            >
                <div
                    class="navbar-start flex items-center gap-2 sm:gap-4 min-w-0"
                >
                    <div class="flex-none lg:hidden">
                        <label
                            for="main-drawer"
                            class="btn btn-ghost btn-circle"
                            aria-label="Abrir menú"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3.75 6.75h16.5M3.75 12h16.5M12 17.25h8.25"
                                ></path>
                            </svg>
                        </label>
                    </div>

                    <a
                        href="/"
                        class="flex items-center gap-3 shrink-0 no-underline group min-w-0"
                    >
                        <div
                            class="relative flex-none flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-2xl bg-neutral-900 text-amber-400 shadow-xl transition-all duration-500 group-hover:bg-amber-500 group-hover:text-white group-hover:rotate-3"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6 sm:w-7 sm:h-7"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M12 2v5m-4 5h8l2 5H6l2-5Z"></path>
                                <path d="M9 22h6"></path><path d="M12 17v5"
                                ></path>
                                <circle
                                    cx="12"
                                    cy="12"
                                    r="1"
                                    fill="currentColor"></circle>
                            </svg>
                        </div>

                        <div class="flex flex-col leading-none truncate">
                            <span
                                class="font-montserrat font-black text-lg sm:text-2xl tracking-tighter text-neutral-800 uppercase truncate"
                            >
                                <span class="hidden xs:inline">Iluminación</span
                                >
                                <span class="xs:hidden">I.</span>
                                <span class="text-amber-600 ml-1">
                                    <span class="hidden xs:inline"
                                        >Hernández</span
                                    >
                                    <span class="xs:hidden">H.</span>
                                </span>
                            </span>
                        </div>
                    </a>
                </div>

                <div class="navbar-center hidden lg:flex">
                    <ul
                        class="flex items-center gap-8 font-inter text-[12px] font-bold tracking-[0.15em] text-neutral-500 uppercase"
                    >
                        {
                            ["Tienda", "Marcas", "Contacto", "Sucursales"].map(
                                (item) => (
                                    <li>
                                        <a
                                            href={`/${item.toLowerCase()}`}
                                            class="relative py-2 whitespace-nowrap transition-colors hover:text-neutral-900 group"
                                        >
                                            {item}
                                            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-amber-500 transition-all duration-300 group-hover:w-full" />
                                        </a>
                                    </li>
                                ),
                            )
                        }
                    </ul>
                </div>

                <div
                    class="navbar-end flex-none flex items-center gap-1 sm:gap-2 md:gap-4 min-w-0"
                    data-header-session-nav
                >
                    <div
                        class="hidden lg:flex flex-col items-end justify-center min-w-0 max-w-44 pr-1 border-r border-neutral-100/80 mr-1"
                    >
                        <span
                            data-session-primary-line
                            class="text-[11px] font-inter font-bold text-neutral-800 truncate max-w-full"
                            >Invitado</span
                        >
                    </div>

                    <a
                        href="/login"
                        data-session-desktop-login
                        class="btn btn-ghost btn-sm hidden sm:inline-flex font-inter font-bold text-[11px] uppercase tracking-widest text-neutral-600 hover:text-amber-600 shrink-0"
                    >
                        Entrar
                    </a>

                    <button
                        class="btn btn-ghost btn-circle shrink-0 group"
                        aria-label="Carrito"
                    >
                        <div class="indicator">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-neutral-600 group-hover:text-amber-600 transition-colors"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"
                                ></path>
                            </svg>
                            <span
                                class="indicator-item badge badge-primary badge-sm h-4 w-4 sm:h-5 sm:w-5 p-0 border-2 border-white font-bold text-[9px] sm:text-[10px] rounded-full"
                                >3</span
                            >
                        </div>
                    </button>

                    <div class="dropdown dropdown-end shrink-0">
                        <label
                            tabindex="0"
                            data-session-avatar-trigger
                            aria-label="Menú de cuenta"
                            class="btn btn-ghost btn-circle avatar border-2 border-neutral-100 hover:border-amber-200 transition-all shadow-sm p-0 overflow-hidden"
                        >
                            <span
                                class="relative block w-8 h-8 sm:w-9 sm:h-9 rounded-full overflow-hidden bg-neutral-100"
                            >
                                <img
                                    data-session-avatar-img
                                    class="absolute inset-0 h-full w-full object-cover hidden"
                                    alt=""
                                    width="36"
                                    height="36"
                                    decoding="async"
                                />
                                <span
                                    data-session-avatar-fallback
                                    class="absolute inset-0 flex items-center justify-center bg-neutral-200 text-[11px] font-bold text-neutral-600"
                                >
                                    <span data-session-avatar-initials>?</span>
                                </span>
                            </span>
                        </label>
                        <ul
                            tabindex="0"
                            class="menu menu-sm dropdown-content mt-4 z-1 p-3 shadow-2xl bg-white rounded-2xl w-56 sm:w-60 border border-neutral-100"
                        >
                            <li
                                class="menu-title text-[10px] uppercase font-bold tracking-widest text-neutral-400 pb-1 border-b border-neutral-50 mb-1"
                            >
                                <span data-session-menu-title>Modo invitado</span>
                            </li>
                            <li class="pb-2">
                                <span
                                    data-session-menu-subtitle
                                    class="text-xs font-inter font-medium text-neutral-500 normal-case tracking-normal whitespace-normal"
                                    >Inicia sesión para guardar preferencias</span
                                >
                            </li>
                            <li data-session-item-login>
                                <a href="/login" class="py-2.5 font-medium"
                                    >Iniciar sesión</a
                                >
                            </li>
                            <li data-session-item-register>
                                <a href="/registro" class="py-2.5 font-medium"
                                    >Crear cuenta</a
                                >
                            </li>
                            <li data-session-item-panel class="hidden">
                                <a href="/perfil" class="py-2.5 font-medium"
                                    >Panel Hernández</a
                                >
                            </li>
                            <li
                                data-session-item-logout
                                class="hidden mt-2 border-t border-neutral-50 pt-2"
                            >
                                <a
                                    href="/cerrar-sesion"
                                    class="text-error font-medium py-2.5"
                                    >Cerrar sesión</a
                                >
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>

        <div class="drawer-side z-110">
            <label for="main-drawer" class="drawer-overlay" aria-label="Cerrar"
            ></label>
            <div
                class="w-72 min-h-full bg-white flex flex-col p-8 shadow-2xl"
                data-header-session-drawer
            >
                <div class="mb-12 flex items-center gap-3">
                    <div
                        class="w-8 h-8 rounded bg-neutral-900 flex items-center justify-center text-amber-400"
                    >
                        <span class="font-black text-xs italic">H.</span>
                    </div>
                    <span
                        class="font-montserrat font-bold text-lg text-neutral-800 tracking-tight"
                        >I. Hernández</span
                    >
                </div>

                <ul
                    class="flex flex-col gap-8 font-inter text-xs font-black uppercase tracking-[0.2em] text-neutral-400"
                >
                    <li>
                        <a
                            href="/tienda"
                            class="hover:text-amber-600 transition-colors"
                            >Tienda</a
                        >
                    </li>
                    <li>
                        <a
                            href="/marcas"
                            class="hover:text-amber-600 transition-colors"
                            >Marcas</a
                        >
                    </li>
                    <li>
                        <a
                            href="/contacto"
                            class="hover:text-amber-600 transition-colors"
                            >Contacto</a
                        >
                    </li>
                    <li>
                        <a
                            href="/sucursales"
                            class="hover:text-amber-600 transition-colors"
                            >Sucursales</a
                        >
                    </li>
                    <li data-session-item-login>
                        <a
                            href="/login"
                            class="hover:text-amber-600 transition-colors"
                            >Iniciar sesión</a
                        >
                    </li>
                    <li data-session-item-register>
                        <a
                            href="/registro"
                            class="hover:text-amber-600 transition-colors"
                            >Registro</a
                        >
                    </li>
                    <li data-session-item-panel class="hidden">
                        <a
                            href="/perfil"
                            class="hover:text-amber-600 transition-colors"
                            >Panel Hernández</a
                        >
                    </li>
                    <li data-session-item-logout class="hidden">
                        <a
                            href="/cerrar-sesion"
                            class="hover:text-red-600 transition-colors"
                            >Cerrar sesión</a
                        >
                    </li>
                </ul>

                <div
                    class="mt-auto flex items-center gap-4 bg-neutral-50 p-4 rounded-2xl border border-neutral-100/80"
                >
                    <div class="shrink-0">
                        <span
                            class="relative block w-11 h-11 rounded-full overflow-hidden shadow-sm ring-2 ring-white"
                        >
                            <img
                                data-session-avatar-img
                                class="absolute inset-0 h-full w-full object-cover hidden"
                                alt=""
                                width="44"
                                height="44"
                                decoding="async"
                            />
                            <span
                                data-session-avatar-fallback
                                class="absolute inset-0 flex items-center justify-center bg-neutral-200 text-xs font-bold text-neutral-600"
                            >
                                <span data-session-avatar-initials>?</span>
                            </span>
                        </span>
                    </div>
                    <div class="overflow-hidden min-w-0 flex-1">
                        <span data-session-menu-title class="sr-only"></span>
                        <p
                            data-session-primary-line
                            class="text-[11px] font-black text-neutral-800 uppercase truncate tracking-tight"
                        >
                            Invitado
                        </p>
                        <p
                            data-session-menu-subtitle
                            class="text-[10px] text-neutral-400 font-inter mt-1 line-clamp-2"
                        >
                            Inicia sesión para una experiencia personalizada
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<script>
    import { tryCreateBrowserAuthGateway } from "../auth/client/create-browser-auth-gateway";
    import { loadClientSession } from "../auth/application/load-client-session.use-case";
    import { applyHeaderSessionToDocument } from "../auth/client/apply-header-session";

    async function syncHeaderSession() {
        const gateway = tryCreateBrowserAuthGateway();
        if (!gateway) {
            applyHeaderSessionToDocument({ kind: "guest" });
            return;
        }
        const session = await loadClientSession(gateway);
        applyHeaderSessionToDocument(session);
    }

    void syncHeaderSession();
</script>
