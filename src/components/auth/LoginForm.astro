---
const postLoginPath = Astro.url.searchParams.get("redirect") ?? "/";
---

<div
    class="bg-white border border-neutral-100 shadow-[0_10px_30px_rgba(0,0,0,0.03)] rounded-3xl p-8 md:p-10"
>
    <h2
        class="text-xl font-montserrat font-bold text-neutral-800 mb-2 tracking-tight"
    >
        Iniciar sesión
    </h2>
    <p class="text-sm text-neutral-500 font-inter mb-8">
        Accede con tu correo o continúa con Google.
    </p>

    <div id="login-config" data-redirect={postLoginPath} class="hidden"></div>

    <div
        id="login-env-alert"
        class="alert alert-warning text-sm mb-6 hidden"
        role="alert"
    >
        Falta <code class="text-xs">PUBLIC_API_URL</code> en el entorno del
        front. Añade la URL base del API (por ejemplo
        <code class="text-xs">http://localhost:3000</code>).
    </div>

    <div
        id="login-error"
        class="alert alert-error text-sm mb-6 hidden min-w-0 max-w-full"
        role="alert"
    ></div>

    <form id="login-form" class="space-y-5">
        <div class="form-control w-full">
            <label class="label pb-1.5" for="login-email">
                <span
                    class="label-text font-bold text-neutral-400 uppercase tracking-widest text-[10px]"
                    >Correo electrónico</span
                >
            </label>
            <input
                id="login-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="input input-bordered h-11 bg-neutral-50 border-neutral-200 focus:outline-amber-500/50 w-full text-sm font-inter"
                placeholder="tu@correo.com"
            />
        </div>

        <div class="form-control w-full">
            <label class="label pb-1.5" for="login-password">
                <span
                    class="label-text font-bold text-neutral-400 uppercase tracking-widest text-[10px]"
                    >Contraseña</span
                >
            </label>
            <input
                id="login-password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                class="input input-bordered h-11 bg-neutral-50 border-neutral-200 focus:outline-amber-500/50 w-full text-sm font-inter"
                placeholder="••••••••"
            />
        </div>

        <label class="label cursor-pointer justify-start gap-3 py-0">
            <input
                id="login-remember"
                name="rememberMe"
                type="checkbox"
                class="checkbox checkbox-sm checkbox-neutral rounded border-neutral-300"
            />
            <span class="label-text text-sm text-neutral-600 font-inter"
                >Mantener sesión iniciada</span
            >
        </label>

        <button
            type="submit"
            id="login-submit"
            class="btn btn-neutral btn-block h-12 rounded-xl text-white font-montserrat font-bold tracking-widest text-[11px] shadow-md hover:bg-amber-600 transition-all active:scale-[0.98]"
        >
            ENTRAR
        </button>
    </form>

    <div class="divider text-neutral-400 text-xs font-inter my-8">o</div>

    <button
        type="button"
        id="login-google"
        class="btn btn-outline btn-block h-12 rounded-xl border-neutral-200 font-inter font-semibold text-sm gap-2 hover:border-amber-500 hover:bg-amber-50"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            class="shrink-0"
            ><path
                fill="currentColor"
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            ></path><path
                fill="currentColor"
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            ></path><path
                fill="currentColor"
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            ></path><path
                fill="currentColor"
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            ></path></svg
        >
        Continuar con Google
    </button>

    <p class="text-center text-sm text-neutral-500 font-inter mt-8">
        ¿No tienes cuenta?
        <a href="/registro" class="link link-primary font-semibold text-amber-600"
            >Crear cuenta</a
        >
    </p>
</div>

<script>
    import { tryCreateBrowserAuthGateway } from "../../auth/client/create-browser-auth-gateway";
    import { loginWithEmail } from "../../auth/application/login-with-email.use-case";
    import { loginWithGoogle } from "../../auth/application/login-with-google.use-case";
    import { applyTruncatableHints } from "../../presentation/ui/truncatable-text";

    const cfg = document.getElementById("login-config");
    const redirectPath =
        cfg instanceof HTMLElement ? cfg.dataset.redirect ?? "/" : "/";

    const envAlert = document.getElementById("login-env-alert");
    const errorBox = document.getElementById("login-error");
    const form = document.getElementById("login-form");
    const submitBtn = document.getElementById("login-submit");
    const googleBtn = document.getElementById("login-google");

    const gateway = tryCreateBrowserAuthGateway();
    if (!gateway && envAlert) {
        envAlert.classList.remove("hidden");
    }

    function showError(message: string) {
        if (!errorBox) return;
        errorBox.textContent = message;
        errorBox.classList.remove("hidden");
        errorBox.classList.add("line-clamp-4", "break-words");
        applyTruncatableHints(errorBox, message);
    }

    function hideError() {
        if (!errorBox) return;
        errorBox.classList.add("hidden");
        errorBox.classList.remove("line-clamp-4", "break-words");
        applyTruncatableHints(errorBox, "");
    }

    function setLoading(loading: boolean) {
        if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.disabled = loading;
            submitBtn.classList.toggle("btn-loading", loading);
        }
        if (googleBtn instanceof HTMLButtonElement) {
            googleBtn.disabled = loading;
        }
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        hideError();
        if (!gateway) {
            showError("Configura PUBLIC_API_URL para usar el inicio de sesión.");
            return;
        }
        const emailInput = document.getElementById("login-email");
        const passwordInput = document.getElementById("login-password");
        const rememberInput = document.getElementById("login-remember");
        if (
            !(emailInput instanceof HTMLInputElement) ||
            !(passwordInput instanceof HTMLInputElement)
        ) {
            return;
        }
        setLoading(true);
        const result = await loginWithEmail(gateway, {
            email: emailInput.value,
            password: passwordInput.value,
            rememberMe:
                rememberInput instanceof HTMLInputElement
                    ? rememberInput.checked
                    : undefined,
            callbackURL: `${window.location.origin}${redirectPath}`,
        });
        setLoading(false);
        if (result.ok) {
            window.location.assign(redirectPath);
            return;
        }
        showError(result.message);
    });

    googleBtn?.addEventListener("click", async () => {
        hideError();
        if (!gateway) {
            showError("Configura PUBLIC_API_URL para usar Google.");
            return;
        }
        setLoading(true);
        const origin = window.location.origin;
        const result = await loginWithGoogle(gateway, {
            callbackURL: `${origin}${redirectPath}`,
            errorCallbackURL: `${origin}/login`,
        });
        setLoading(false);
        if (result.ok) {
            window.location.assign(result.data.redirectUrl);
            return;
        }
        showError(result.message);
    });
</script>
